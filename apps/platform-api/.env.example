# Platform API (apps/platform-api) 환경변수.

# PostgreSQL 연결 문자열 (비우면 InMemoryPlatformRepository 사용 — 테스트용)
DATABASE_URL=postgresql+psycopg://platform:platform@localhost:5432/platform
# 관리자 액세스 토큰 서명용 비밀키 (운영 시 반드시 무작위 값으로 교체)
AUTH_TOKEN_SECRET=replace-with-a-random-secret
# 초대 링크에 쓰일 공개 베이스 URL (Candidate Web 주소)
INVITE_PUBLIC_BASE_URL=http://localhost:3000
# Detection Service 주소 (비우면 위험 평가 호출 비활성)
DETECTION_SERVICE_URL=http://localhost:8003
# 허용할 프론트엔드 출처(CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
