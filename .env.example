# 루트 통합(overview) 환경변수 예시.
# 각 앱/서비스는 자체 .env.example을 가지므로, 실제 설정은 해당 폴더에서 하세요:
#   - apps/platform-api/.env.example   (Platform API)
#   - apps/admin-web/.env.example      (Admin Web)
#   - frontend/.env.example            (Candidate Web)
#   - ai_engine/.env.example           (AI 엔진 / 레드팀 시뮬레이터)
# 아래는 docker-compose로 전체 스택을 띄울 때 참고하는 핵심 값들입니다.

# Platform API가 허용할 프론트엔드 출처(CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# 프론트엔드(Candidate Web)가 호출할 Platform API 주소
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8001
# Platform API → Detection Service 주소 (비우면 위험 평가 비활성)
DETECTION_SERVICE_URL=http://localhost:8003
